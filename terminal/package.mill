package build.terminal

import mill.*
import mill.javalib.DepSyntax

object `package` extends build.TuiPublishModule {

  def artifactName = "tui-terminal"

  def moduleDescription = "JLine 3 terminal backend for the tui library."

  def moduleDeps = Seq(build.core)

  def mvnDeps = super.mvnDeps() ++ Seq(
    // stay on the JLine 3.x line; 4.x is too new to be a safe default dependency yet
    mvn"org.jline:jline:3.30.13",
  )

  object test extends TuiTests
}
